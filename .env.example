# =============================================================================
# Cover Site Template - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Google Analytics (Optional)
# -----------------------------------------------------------------------------
# Get your Measurement ID from Google Analytics 4
# Format: G-XXXXXXXXXX
# If not set, analytics will be disabled
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Supabase Configuration (Required for Newsletter, Contact Form & Audio)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings
# Project URL format: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# SendGrid Email (Required for Contact Form Notifications)
# -----------------------------------------------------------------------------
# Get your API key from SendGrid
# SENDGRID_FROM_EMAIL must be a verified sender in your SendGrid account
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_TO_EMAIL=
SENDGRID_CC_EMAIL=

# -----------------------------------------------------------------------------
# Newsletter Admin Authentication (Optional)
# -----------------------------------------------------------------------------
# Set a secure random key for newsletter admin panel access
# Generate with: openssl rand -base64 32
# If not set, admin endpoints will be disabled
NEWSLETTER_ADMIN_KEY=

# -----------------------------------------------------------------------------
# fal.ai (Required for TTS and Image Editing - dev only)
# -----------------------------------------------------------------------------
FAL_KEY=

# -----------------------------------------------------------------------------
# Site Name (Used in email notifications)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Main site configuration is in site.config.ts
# Edit that file to customize:
# - Company name, contact info, branding
# - Theme selection (professional, modern, elegant, minimal, warm)
# - Navigation, social links, services
# - SEO metadata
# - Blog settings
# =============================================================================
