# =============================================================================
# WCW Site Template - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Google Analytics (Optional)
# -----------------------------------------------------------------------------
# Get your Measurement ID from Google Analytics 4
# Format: G-XXXXXXXXXX
# If not set, analytics will be disabled
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Supabase Configuration (Required for Newsletter & Audio Features)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings
# Project URL format: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Newsletter Admin Authentication (Optional)
# -----------------------------------------------------------------------------
# Set a secure random key for newsletter admin panel access
# Generate with: openssl rand -base64 32
# If not set, admin endpoints will be disabled
NEWSLETTER_ADMIN_KEY=

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Main site configuration is in site.config.ts
# Edit that file to customize:
# - Company name, contact info, branding
# - Theme selection (professional, modern, elegant, minimal, warm)
# - Navigation, social links, services
# - SEO metadata
# - Blog settings
# =============================================================================
